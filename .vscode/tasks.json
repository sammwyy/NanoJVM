{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build NanoJVM",
            "type": "shell",
            "command": "make nanojvm",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Compile Samples",
            "type": "shell",
            "command": "javac -d samples samples/*.java",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Run nanojvm",
            "type": "shell",
            "command": "./nanojvm samples/${fileBasenameNoExtension}.class",
            "group": "test",
            "dependsOn": [
                "Build NanoJVM",
                "Compile Samples"
            ],
            "problemMatcher": []
        }
    ]
}